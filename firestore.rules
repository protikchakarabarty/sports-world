rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Fan Prediction Polls =====
    match /polls/{pollId} {

      // Poll metadata is read-only
      allow read: if true;
      allow write: if false;

      match /votes/{userId} {

        // Anyone can see vote counts and percentages
        allow read: if true;

        // Allow first vote only (document must not exist yet)
        allow create: if true;

        // Prevent changing or deleting a vote after it's cast
        allow update: if false;
        allow delete: if false;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
